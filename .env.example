# ═══════════════════════════════════════════════════════════
# YouTube Channel Cloner — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Admin Credentials (REQUIRED) ──────────────────────────
# The dashboard will NOT start without these
DASH_USER=admin
DASH_PASS=          # REQUIRED: Set a strong password (min 12 chars)
DASH_EMAIL=admin@yourdomain.com

# ── AI Provider (REQUIRED for content generation) ─────────
LAOZHANG_API_KEY=sk-...
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1
AI_MODEL=claude-sonnet-4-6

# ── Encryption (REQUIRED for API key storage) ─────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── CSRF Secret (REQUIRED) ───────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SECRET=

# ── Google OAuth (optional — for Drive export) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8888/api/algorithm/oauth/callback

# ── NotebookLM (optional — for advanced analysis) ─────────
# Base64-encoded storage_state.json content
NOTEBOOKLM_CREDENTIALS=
NOTEBOOKLM_CONTEXT=

# ── Server Settings ──────────────────────────────────────
PORT=8888
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:8888,https://yourdomain.com

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_AI=5/minute
RATE_LIMIT_ANALYSIS=3/minute
